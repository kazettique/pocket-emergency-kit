# Re:Earth CMS connection
#
# In dev, leave VITE_CMS_BASE_URL empty — sync.ts then emits relative URLs
# (/api/p/...) that Vite's server.proxy forwards to CMS_PROXY_TARGET below.
# Same-origin from the browser's POV, so no CORS.
#
# For a cross-origin production deploy, either (a) put a reverse proxy in
# front of the PWA that mirrors this rule, or (b) enable CORS on the CMS
# for the PWA origin and set VITE_CMS_BASE_URL to the full API host.
VITE_CMS_BASE_URL=
VITE_CMS_WORKSPACE=your-workspace-alias
VITE_CMS_PROJECT=your-project-alias

# Dev-only: the Vite proxy target for /api/p/* requests. Point this at the
# Re:Earth CMS public-read API host (same host as the integration API — the
# `api.` subdomain of the CMS UI).
CMS_PROXY_TARGET=https://api.cms.test.reearth.dev

# Japan Meteorological Agency
# Tokyo = 130000, Osaka = 270000, find yours at:
# https://www.jma.go.jp/bosai/common/const/area.json
VITE_JMA_AREA_CODE=130000

# MLIT reinfolib API key (apply at https://www.reinfolib.mlit.go.jp/api/request/).
# Approval takes ~1 week; hazard-zone fetch is short-circuited in src/gov/api.ts
# until this is uncommented and filled.
# VITE_MLIT_API_KEY=

# Go importer has its own env file — see importer/.env.example
